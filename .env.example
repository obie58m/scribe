# Google OAuth — https://console.cloud.google.com/apis/credentials
export GOOGLE_CLIENT_ID="your-google-client-id"
export GOOGLE_CLIENT_SECRET="your-google-client-secret"
export GOOGLE_REDIRECT_URI="http://localhost:4000/auth/google/callback"

# Recall.ai — meeting transcription service — https://www.recall.ai/
export RECALL_API_KEY="your-recall-api-key"
export RECALL_REGION="us-west-2"

# Google Gemini — AI content generation — https://aistudio.google.com/apikey
export GEMINI_API_KEY="your-gemini-api-key"

# HubSpot CRM — https://developers.hubspot.com/ → Apps → Auth tab
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write, oauth
export HUBSPOT_CLIENT_ID="your-hubspot-client-id"
export HUBSPOT_CLIENT_SECRET="your-hubspot-client-secret"

# Salesforce CRM — https://login.salesforce.com → Setup → App Manager → New Connected App
# Required scopes: api, refresh_token, openid
export SALESFORCE_CLIENT_ID="your-salesforce-consumer-key"
export SALESFORCE_CLIENT_SECRET="your-salesforce-consumer-secret"
export SALESFORCE_REDIRECT_URI="http://localhost:4000/auth/salesforce/callback"
